---
import { content, installCommand } from '../lib/content'
---

<footer class="site-footer">
  <div class="container site-footer-inner">
    <div class="footer-brand">
      <img src="/logo.png" alt="hpsr.sh logo" class="footer-logo" />
      <div>
        <strong class="footer-brand-name">hpsr.sh</strong>
        <p data-i18n="footer.tagline">{content.es.footer.tagline}</p>
      </div>
    </div>

    <div class="footer-meta">
      <code class="footer-command">{installCommand}</code>
      <div class="footer-links">
        {content.es.footer.links.map((link, index) => (
          <a href={link.href} target="_blank" rel="noreferrer" data-i18n={`footer.links.${index}.label`}>
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>