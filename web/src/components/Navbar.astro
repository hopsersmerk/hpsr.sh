---
import { content } from '../lib/content'
import ThemeToggle from './ThemeToggle.astro'
---

<div class="site-brand-island">
  <a class="brand-link" href="#top" aria-label="hpsr.sh home">
    <span class="brand-logo-shell">
      <img src="/logo.png" alt="hpsr.sh logo" class="brand-logo" />
    </span>
    <span class="brand-name">
      <span class="brand-name-root">hpsr</span><span class="brand-name-ext">.sh</span>
    </span>
  </a>
</div>

<div class="site-controls-island">
  <div class="language-switch" aria-label={content.es.nav.language}>
    <button type="button" class="lang-button" data-language-button="es" aria-pressed="true">ES</button>
    <button type="button" class="lang-button" data-language-button="en" aria-pressed="false">EN</button>
  </div>
  <ThemeToggle />
  <a class="nav-link-gh" data-github-link href="https://github.com/hopsersmerk/hpsr.sh" data-i18n="nav.github">
    {content.es.nav.github}
  </a>
</div>
